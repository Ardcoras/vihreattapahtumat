{% if primary or secondary %}
  <div class="tabs">
    {% if primary %}
      <h2 class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
      <ul>{{ primary }}</ul>
    {% endif %}
    {% if secondary %}
      <h2 class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
      <ul>{{ secondary }}</ul>
    {% endif %}
  </div>
{% endif %}
