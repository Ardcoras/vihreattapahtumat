<article{{ attributes }}>
  {{ title_prefix }}
  {{ title_suffix }}

  <div class="event-layout">

    <div class="event-main">
      <h1 class="event-title">{{ node.label }}</h1>

      {% if event_date_bar %}
        <div class="event-date-bar">
          <svg class="event-date-bar__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <rect x="2" y="3" width="16" height="15" rx="2.5" stroke="currentColor" stroke-width="1.6"/>
            <path d="M2 8h16" stroke="currentColor" stroke-width="1.6"/>
            <path d="M6 2v3M14 2v3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <circle cx="7" cy="13" r="1" fill="currentColor"/>
            <circle cx="10" cy="13" r="1" fill="currentColor"/>
            <circle cx="13" cy="13" r="1" fill="currentColor"/>
          </svg>
          <div>
            <div class="event-date-bar__label">{{ 'Ajankohta'|t }}</div>
            <div class="event-date-bar__value">{{ event_date_bar }}</div>
          </div>
        </div>
      {% endif %}

      {% if node.field_description.processed %}
        <div class="event-body">
          {{ node.field_description.processed }}
        </div>
      {% endif %}
    </div>

    <aside class="event-sidebar">

      <div class="event-actions">
        <a href="{{ path('ical.event', {'node': node.id}) }}" class="btn-primary" download>
          <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
            <path d="M7.5 1.5v8M4 7l3.5 3.5L11 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M1.5 11.5v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          {{ 'Lisää kalenteriini'|t }}
        </a>
      </div>


<div class="sidebar-card">
        <div class="sidebar-card__header">{{ 'Tapahtuman tiedot'|t }}</div>
        <div class="sidebar-card__body">

          {% if event_day %}
            <div class="meta-row">
              <svg class="meta-row__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1.5" y="2.5" width="13" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/>
                <path d="M1.5 6.5h13" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 1.5v2M11 1.5v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              <div class="meta-row__content">
                <span class="meta-row__label">{{ 'Päivä'|t }}</span>
                <span class="meta-row__value">{{ event_day }}</span>
                <span class="meta-row__sub">{{ event_time }}</span>
              </div>
            </div>
            <div class="sidebar-divider"></div>
          {% endif %}

          {% if not node.field_event_organiser.isEmpty %}
            <div class="meta-row">
              <svg class="meta-row__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="5.5" r="3" stroke="currentColor" stroke-width="1.4"/>
                <path d="M2 13.5c0-2.5 2.7-4.5 6-4.5s6 2 6 4.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              <div class="meta-row__content">
                <span class="meta-row__label">{{ 'Järjestäjä'|t }}</span>
                {% for item in node.field_event_organiser %}
                  {% if item.entity %}
                    <a href="{{ path('entity.node.canonical', {'node': item.entity.id}) }}" class="organizer-link">{{ item.entity.label }}</a>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
            <div class="sidebar-divider"></div>
          {% endif %}

          {% if node.field_event_type.entity %}
            <div class="meta-row">
              <svg class="meta-row__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="1.5" y="1.5" width="13" height="13" rx="2" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 8h6M5 5.5h6M5 10.5h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
              </svg>
              <div class="meta-row__content">
                <span class="meta-row__label">{{ 'Tyyppi'|t }}</span>
                <span class="type-badge">{{ node.field_event_type.entity.label }}</span>
              </div>
            </div>
            <div class="sidebar-divider"></div>
          {% endif %}

          <div class="meta-row">
            <svg class="meta-row__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.4"/>
              <path d="M9.5 8L7 6.5v3L9.5 8z" fill="currentColor"/>
            </svg>
            <div class="meta-row__content">
              <span class="meta-row__label">{{ 'Etämahdollisuus'|t }}</span>
              {% if node.field_event_remote.value == 1 %}
                <span class="meta-row__value">{{ 'Kyllä'|t }}</span>
              {% else %}
                <span class="meta-row__value meta-row__value--no">{{ 'Ei'|t }}</span>
              {% endif %}
            </div>
          </div>

        </div>
      </div>

      {% if node.field_place.entity %}
        <div class="sidebar-card">
          <div class="sidebar-card__header">{{ 'Sijainti'|t }}</div>
          <div class="sidebar-card__body">

            <div class="meta-row">
              <svg class="meta-row__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 1.5A4.5 4.5 0 0 1 12.5 6c0 4-4.5 8.5-4.5 8.5S3.5 10 3.5 6A4.5 4.5 0 0 1 8 1.5z" stroke="currentColor" stroke-width="1.4"/>
                <circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.4"/>
              </svg>
              <div class="meta-row__content">
                <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': node.field_place.entity.id}) }}" class="location-venue location-venue--link">{{ node.field_place.entity.label }}</a>
                {% if node.field_place.entity.bundle == 'place' %}
                  <span class="location-address">
                    {{- node.field_place.entity.field_street_address.value -}}
                    {% if node.field_place.entity.field_municipality.entity %}
                      <br>{{ node.field_place.entity.field_municipality.entity.label }}
                    {% endif %}
                  </span>
                {% endif %}
              </div>
            </div>

            {% if event_place_embed is defined %}
              <div class="event-map">
                {{ event_place_embed }}
              </div>
            {% endif %}

            {% if node.field_place.entity.description.processed %}
              <div class="place-description">
                {{ node.field_place.entity.description.processed }}
              </div>
            {% endif %}

            {% if place_map_url is defined %}
              <a href="{{ place_map_url }}" target="_blank" rel="noopener noreferrer" class="map-external-link">
                <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                  <path d="M6.5 1h3.5v3.5M10 1L5.5 5.5M4.5 2H2a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V6.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                {{ 'Avaa kartalla'|t }}
              </a>
            {% endif %}

          </div>
        </div>
      {% endif %}

    </aside>
  </div>
</article>
