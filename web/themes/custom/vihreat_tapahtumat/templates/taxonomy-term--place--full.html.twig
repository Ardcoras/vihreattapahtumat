<article{{ attributes }}>
  {{ title_prefix }}
  {{ title_suffix }}

  <div class="place-layout">

    <div class="place-main">

      <h1 class="place-title">{{ term.label }}</h1>

      {% if term.field_municipality.entity %}
        <div class="place-city">
          <svg class="place-city__icon" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M7 1A3.5 3.5 0 0 1 10.5 4.5c0 3.5-3.5 7-3.5 7S3.5 8 3.5 4.5A3.5 3.5 0 0 1 7 1z" stroke="currentColor" stroke-width="1.3"/>
            <circle cx="7" cy="4.5" r="1.2" stroke="currentColor" stroke-width="1.3"/>
          </svg>
          <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': term.field_municipality.entity.id}) }}" class="place-city__link">
            {{- term.field_municipality.entity.label -}}
          </a>
        </div>
      {% endif %}

      {% if term.description.processed %}
        <div class="place-description">{{ term.description.processed }}</div>
      {% endif %}

      {% if term.field_street_address.value or term.field_municipality.entity %}
        <div class="place-meta">
          <div class="place-meta-row">
            <svg class="place-meta-row__icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 1.5A4.5 4.5 0 0 1 12.5 6c0 4-4.5 8.5-4.5 8.5S3.5 10 3.5 6A4.5 4.5 0 0 1 8 1.5z" stroke="currentColor" stroke-width="1.4"/>
              <circle cx="8" cy="6" r="1.5" stroke="currentColor" stroke-width="1.4"/>
            </svg>
            <div class="place-meta-row__content">
              <span class="place-meta-row__label">{{ 'Osoite'|t }}</span>
              <span class="place-meta-row__value">
                {{- term.field_street_address.value -}}
                {% if term.field_municipality.entity %}
                  <br>{{ term.field_municipality.entity.label }}
                {% endif %}
              </span>
            </div>
          </div>
        </div>
      {% endif %}

    </div>

    {% if content.field_location or term.field_street_address.value %}
      <aside class="place-sidebar">
        <div class="map-card">
          {% if content.field_location %}
            <div class="map-card__map">
              {{ content.field_location }}
            </div>
          {% endif %}
          <div class="map-card__footer">
            {% if term.field_street_address.value %}
              <div class="map-card__address">{{ term.field_street_address.value }}</div>
            {% endif %}
            {% if term.field_municipality.entity %}
              <div class="map-card__city">{{ term.field_municipality.entity.label }}</div>
            {% endif %}
            {% if place_map_url is defined %}
              <a href="{{ place_map_url }}" target="_blank" rel="noopener noreferrer" class="map-card__link">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M7 1h4v4M11 1L5.5 6.5M4.5 2.5H2a1 1 0 0 0-1 1v6.5a1 1 0 0 0 1 1h6.5a1 1 0 0 0 1-1V7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                {{ 'Avaa kartalla'|t }}
              </a>
            {% endif %}
          </div>
        </div>
      </aside>
    {% endif %}

  </div>

  {% if upcoming_events is defined %}
    <section class="events-section">
      <div class="events-section__header">
        <h2 class="events-section__title">{{ 'Tulevat tapahtumat tässä paikassa'|t }}</h2>
        {% if upcoming_events %}
          <span class="events-section__count">{{ upcoming_events|length }} {{ 'tapahtumaa'|t }}</span>
        {% endif %}
      </div>

      {% if upcoming_events %}
        <div class="event-list">
          {% for ev in upcoming_events %}
            <a href="{{ ev.url }}" class="event-row">
              <div class="event-row__date">
                <div class="event-row__day">{{ ev.date_day }}</div>
                <div class="event-row__month">{{ ev.date_month }}</div>
              </div>
              <div class="event-row__body">
                <div class="event-row__title">{{ ev.title }}</div>
                <div class="event-row__meta-text">
                  {{- ev.time_text -}}
                  {% if ev.time_text and ev.organiser %} · {% endif %}
                  {{- ev.organiser -}}
                </div>
              </div>
              <div class="event-row__right">
                {% if ev.type_label %}
                  <span class="event-row__badge">{{ ev.type_label }}</span>
                {% endif %}
                <svg class="event-row__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <p class="events-section__empty">{{ 'Ei tulevia tapahtumia.'|t }}</p>
      {% endif %}

      {% if past_events is defined and past_events %}
        <button class="past-toggle" data-past-toggle type="button">
          <svg class="past-toggle__chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M4 5.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{ 'Näytä aiemmat tapahtumat'|t }} ({{ past_events|length }})
        </button>
        <div class="event-list event-list--past" hidden data-past-list>
          {% for ev in past_events %}
            <a href="{{ ev.url }}" class="event-row">
              <div class="event-row__date">
                <div class="event-row__day">{{ ev.date_day }}</div>
                <div class="event-row__month">{{ ev.date_month }}</div>
              </div>
              <div class="event-row__body">
                <div class="event-row__title">{{ ev.title }}</div>
                <div class="event-row__meta-text">
                  {{- ev.time_text -}}
                  {% if ev.time_text and ev.organiser %} · {% endif %}
                  {{- ev.organiser -}}
                </div>
              </div>
              <div class="event-row__right">
                {% if ev.type_label %}
                  <span class="event-row__badge">{{ ev.type_label }}</span>
                {% endif %}
                <svg class="event-row__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </a>
          {% endfor %}
        </div>
      {% endif %}

    </section>
  {% endif %}

</article>
